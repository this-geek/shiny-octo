{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "rootDir": ".",
    "noEmit": true,
    "composite": false,
    "strict": true,
    "types": []
  },
  "include": ["app/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "build", "dist"]
}

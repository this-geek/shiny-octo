# Shopify app credentials — from Partners Dashboard > Apps > your app > API credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# 256-bit master key for AES-GCM / HKDF per-shop key derivation
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=

# Resend API key for transactional email — https://resend.com/api-keys
RESEND_API_KEY=

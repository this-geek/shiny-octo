{% comment %}
  b2b-preapplication.liquid — Theme App Embed (Phase 1J §7).

  Merchant-installable pre-application landing block. Renders a hero +
  benefit bullets + CTA on a single page path (defaults to `/pages/wholesale`)
  so prospects have somewhere to land from social, email, or paid traffic
  before they hit the application form. The CTA points at whatever path the
  merchant configured the b2b-application block on.

  Pure Liquid — no JS, no App Proxy roundtrip. The application form lives in
  a separate block (`b2b-application.liquid`) so a single embed enabling +
  two configurable page paths cover both landings.
{% endcomment %}

{%- assign landing_path = block.settings.landing_path | default: '/pages/wholesale' | strip -%}
{%- assign current_path = request.path | default: '' -%}
{%- assign path_matches = false -%}
{%- if landing_path != blank and current_path == landing_path -%}
  {%- assign path_matches = true -%}
{%- endif -%}

{%- if path_matches -%}
  <section class="b2b-pre" aria-labelledby="b2b-pre-heading">
    <h1 id="b2b-pre-heading" class="b2b-pre__heading">
      {{ block.settings.heading | default: 'Wholesale that just works' }}
    </h1>
    {%- if block.settings.subheading != blank -%}
      <p class="b2b-pre__subheading">{{ block.settings.subheading }}</p>
    {%- endif -%}

    {%- assign bullets = block.settings.bullets | default: '' | strip -%}
    {%- if bullets != blank -%}
      <ul class="b2b-pre__bullets">
        {%- assign lines = bullets | newline_to_br | split: '<br />' -%}
        {%- for line in lines -%}
          {%- assign clean = line | strip -%}
          {%- if clean != blank -%}
            <li>{{ clean }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- assign cta_path = block.settings.cta_path | default: '/pages/wholesale-apply' | strip -%}
    {%- assign cta_label = block.settings.cta_label | default: 'Apply for a wholesale account' -%}
    <a class="b2b-pre__cta" href="{{ cta_path }}">{{ cta_label }}</a>

    {%- if block.settings.footnote != blank -%}
      <p class="b2b-pre__footnote">{{ block.settings.footnote }}</p>
    {%- endif -%}
  </section>

  <style>
    .b2b-pre {
      max-width: 720px;
      margin: 2.5rem auto;
      padding: 0 1rem;
      font: inherit;
    }
    .b2b-pre__heading { font-size: 2rem; line-height: 1.2; margin: 0 0 0.5rem; }
    .b2b-pre__subheading { color: rgba(0,0,0,0.7); font-size: 1.1rem; margin: 0 0 1.5rem; }
    .b2b-pre__bullets { margin: 0 0 1.5rem; padding-left: 1.25rem; line-height: 1.6; }
    .b2b-pre__cta {
      display: inline-block;
      padding: 0.75rem 1.25rem;
      background: #111;
      color: #fff;
      text-decoration: none;
      border-radius: 4px;
      font-weight: 600;
    }
    .b2b-pre__cta:hover { background: #222; }
    .b2b-pre__footnote { color: rgba(0,0,0,0.55); font-size: 0.85rem; margin: 1rem 0 0; }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "B2B Wholesale Landing",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "landing_path",
      "label": "Landing page path",
      "info": "The URL path where the block renders. The block emits nothing on any other path so it's safe to leave the embed enabled globally.",
      "default": "/pages/wholesale"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wholesale that just works"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Apply once, get approved, and order at your tier price with terms that suit your business."
    },
    {
      "type": "textarea",
      "id": "bullets",
      "label": "Bullet points",
      "info": "One bullet per line.",
      "default": "Tier-based pricing applied automatically\nDealer-only resources and price lists\nOrder by case or pallet, with payment terms after approval"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button text",
      "default": "Apply for a wholesale account"
    },
    {
      "type": "text",
      "id": "cta_path",
      "label": "CTA target path",
      "info": "Path of the page where the b2b-application block is enabled.",
      "default": "/pages/wholesale-apply"
    },
    {
      "type": "textarea",
      "id": "footnote",
      "label": "Footnote",
      "default": "Approvals usually take 1–2 business days."
    }
  ]
}
{% endschema %}

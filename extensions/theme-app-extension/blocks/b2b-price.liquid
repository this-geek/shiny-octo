{% comment %}
  b2b-price.liquid — Theme App Embed (Phase 1B, restructured Phase 1H+).

  App embed (target=body) so merchants enable it once in the theme editor's
  App embeds panel rather than dropping it into every section. It does
  nothing on non-product templates so adding it globally is safe.

  Renders the tier-discounted price client-side via assets/b2b-price.js. The
  block exposes the data the JS needs as data-* attributes; no inline scripts
  (CSP per §9 of the requirements). The discount math itself lives in
  assets/b2b-price.js and mirrors packages/shared/src/pricing.ts; the Phase 1D
  parity test asserts they cannot drift.

  Liquid-side hide for `b2b_only` products: when the product carries the
  metafield b2b.b2b_only == true and the customer is not B2B, we render a
  server-side <style> rule that hides the .product-form and .price selectors
  (Dawn + most modern themes). This is defence-in-depth alongside the
  template-level 404 guard the merchant pastes into their theme per
  MANUAL_STEPS.md §10.2 (DECISIONS #6).
{% endcomment %}

{%- if template contains 'product' and product -%}
  {%- assign b2b_only = product.metafields.b2b.b2b_only -%}
  {%- assign customer_is_b2b = false -%}
  {%- if customer and customer.b2b? -%}
    {%- assign customer_is_b2b = true -%}
  {%- endif -%}

  {%- assign app_proxy_path = shop.metafields.b2b.app_proxy_path | default: 'apps/b2b' -%}

  {%- if b2b_only and customer_is_b2b == false -%}
    <style>
      .product-form, .product__price, .price, .product-form__buttons { display: none !important; }
    </style>
  {%- endif -%}

  <div
    data-b2b-price-block
    data-product-id="{{ product.id }}"
    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
    data-base-price-cents="{{ product.selected_or_first_available_variant.price }}"
    data-b2b-only="{% if b2b_only %}true{% else %}false{% endif %}"
    data-customer-is-b2b="{% if customer_is_b2b %}true{% else %}false{% endif %}"
    data-app-proxy-path="{{ app_proxy_path }}"
    data-show-savings-badge="{% if block.settings.show_savings_badge %}true{% else %}false{% endif %}"
    data-price-display="{{ block.settings.price_display }}"
  ></div>

  <script src="{{ 'b2b-price.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "B2B Tier Price",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_savings_badge",
      "label": "Show savings badge",
      "default": true
    },
    {
      "type": "select",
      "id": "price_display",
      "label": "Price display mode",
      "options": [
        { "value": "replace", "label": "Replace standard price" },
        { "value": "alongside", "label": "Show alongside standard price" }
      ],
      "default": "alongside"
    }
  ]
}
{% endschema %}

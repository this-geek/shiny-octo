{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "composite": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ES2022"]
  },
  "references": [
    { "path": "./packages/shared" },
    { "path": "./apps/worker" }
  ],
  "exclude": ["node_modules", "**/node_modules"]
}
